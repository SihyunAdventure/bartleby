{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bartleby",
  "version": "0.1.7",
  "identifier": "com.heybartleby.bartleby",
  "build": {
    "beforeDevCommand": "pnpm build:sidecar && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm build:sidecar",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Bartleby",
        "width": 1280,
        "height": 860,
        "acceptFirstMouse": true
      },
      {
        "label": "dictation",
        "url": "index.html?dictation",
        "title": "Dictation",
        "width": 280,
        "height": 76,
        "visible": false,
        "focus": false,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/audio/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "15.0",
      "signingIdentity": "Developer ID Application: Notique Inc. (7M2DZPHB8R)",
      "hardenedRuntime": true,
      "providerShortName": "7M2DZPHB8R",
      "entitlements": "entitlements.plist"
    },
    "externalBin": [
      "binaries/bartleby-mic"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBMDRGQ0RERjI2MEM0MTYKUldRV3hHRHkzZndFU2wycktYN0krTTM0ZlBudEFDM08yL0V5d0I1RUhYdHVJQkZTS3dJL3RjQXYK",
      "endpoints": [
        "https://heybartleby.com/latest.json"
      ]
    }
  }
}
